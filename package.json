{
  "name": "super-reps",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "expo export -p web",
    "preview:web": "expo serve",
    "sync:vercel-env": "node scripts/sync-vercel-env.mjs",
    "deploy": "npm run build:web && vercel deploy --prod",
    "db:setup": "node --env-file=.env scripts/db-setup.mjs",
    "db:exercises": "node --env-file=.env scripts/import-exercises.mjs",
    "db:exercises:dry": "node --env-file=.env scripts/import-exercises.mjs --dry-run --limit=3",
    "db:exercises:fast": "node --env-file=.env scripts/import-exercises.mjs --skip-images",
    "typecheck": "tsc --noEmit",
    "generate:assets": "node scripts/generate-brand-assets.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@hookform/resolvers": "^5.2.2",
    "@sparticuz/chromium": "^131.0.1",
    "@supabase/supabase-js": "^2.104.1",
    "@vercel/node": "^5.7.13",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.33",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "groq-sdk": "^1.1.2",
    "nativewind": "^4.2.3",
    "puppeteer-core": "^24.42.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.73.1",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.4",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "tailwindcss": "^3.4.19",
    "victory-native": "^41.20.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/react": "~19.1.0",
    "dotenv": "^16.5.0",
    "postgres": "^3.4.9",
    "sharp": "^0.34.5",
    "typescript": "~5.9.2"
  },
  "private": true,
  "engines": {
    "node": ">=20"
  }
}
