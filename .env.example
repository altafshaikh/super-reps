# ─── Used at runtime (web + iOS + Android) — inlined into the JS bundle (EXPO_PUBLIC_* only) ───
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Production origin (no trailing slash): confirmation-email links, native API calls — required on iOS/Android
# EXPO_PUBLIC_SITE_URL=https://your-app.vercel.app
EXPO_PUBLIC_GROQ_API_KEY=gsk_...

# ─── Dev machine ONLY — not used by the app, not for Vercel / EAS runtime ───
# Direct Postgres access for `npm run db:setup` (apply schema + seed from this laptop/CI).
# All normal reads/writes go through Supabase HTTP API + anon key above (same on web and mobile).
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@...pooler.supabase.com:6543/postgres
